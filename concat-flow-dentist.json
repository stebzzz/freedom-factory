    "maxImageDurationSec": 6,
    "perImage": [
      {
        "image": "scene_000.png",
        "triggerText": "You're sitting in the dentist's chair."
      },
      {
        "image": "scene_001.png",
        "triggerText": "The drill spins."
      },
      {
        "image": "scene_002.png",
        "triggerText": "Anesthesia numbs your jaw."
      },
      {
        "image": "scene_003.png",
        "triggerText": "You feel a faint pressure,"
      },
      {
        "image": "scene_004.png",
        "triggerText": "almost nothing."
      },
      {
        "image": "scene_005.png",
        "triggerText": "In an hour,"
      },
      {
        "image": "scene_006.png",
        "triggerText": "it's over,"
      },
      {
        "image": "scene_007.png",
        "triggerText": "and you'll go home and forget the whole thing ever happened."
      },
      {
        "image": "scene_008.png",
        "triggerText": "But for 99% of human history,"
      },
      {
        "image": "scene_009.png",
        "triggerText": "this moment didn't exist."
      },
      {
        "image": "scene_010.png",
        "triggerText": "No drill."
      },
      {
        "image": "scene_011.png",
        "triggerText": "No anesthesia."
      },
      {
        "image": "scene_012.png",
        "triggerText": "No chair."
      },
      {
        "image": "scene_013.png",
        "triggerText": "When a tooth started rotting,"
      },
      {
        "image": "scene_014.png",
        "triggerText": "you had two options."
      },
      {
        "image": "scene_015.png",
        "triggerText": "Endure the pain until the tooth fell out on its own,"
      },
      {
        "image": "scene_016.png",
        "triggerText": "or find someone with a sharp tool and a lot of nerve."
      },
      {
        "image": "scene_017.png",
        "triggerText": "For 300,000 years,"
      },
      {
        "image": "scene_018.png",
        "triggerText": "every single one of your ancestors lived without anything you'd recognize today."
      },
      {
        "image": "scene_019.png",
        "triggerText": "No toothbrush."
      },
      {
        "image": "scene_020.png",
        "triggerText": "No toothpaste."
      },
      {
        "image": "scene_021.png",
        "triggerText": "No antibiotics."
      },
      {
        "image": "scene_022.png",
        "triggerText": "So how did they survive?"
      },
      {
        "image": "scene_023.png",
        "triggerText": "How did our species cross three hundred millennia carrying mouths full of teeth that could kill them at any moment?"
      },
      {
        "image": "scene_024.png",
        "triggerText": "The answer changes everything you think you know about oral health."
      },
      {
        "image": "scene_025.png",
        "triggerText": "Let's start with a myth,"
      },
      {
        "image": "scene_026.png",
        "triggerText": "because almost everyone believes it."
      },
      {
        "image": "scene_027.png",
        "triggerText": "We've been told for decades that hunter-gatherers had perfect teeth."
      },
      {
        "image": "scene_028.png",
        "triggerText": "No sugar,"
      },
      {
        "image": "scene_029.png",
        "triggerText": "no grains,"
      },
      {
        "image": "scene_030.png",
        "triggerText": "no bread."
      },
      {
        "image": "scene_031.png",
        "triggerText": "Just meat,"
      },
      {
        "image": "scene_032.png",
        "triggerText": "berries, and roots."
      },
      {
        "image": "scene_033.png",
        "triggerText": "A pristine mouth."
      },
      {
        "image": "scene_034.png",
        "triggerText": "This is wrong."
      },
      {
        "image": "scene_035.png",
        "triggerText": "In 2014,"
      },
      {
        "image": "scene_036.png",
        "triggerText": "a study published in the Proceedings of the National Academy of Sciences shattered the idea."
      },
      {
        "image": "scene_037.png",
        "triggerText": "Researchers analyzed 52 hunter-gatherer skeletons from a cave called Taforalt,"
      },
      {
        "image": "scene_038.png",
        "triggerText": "in Morocco."
      },
      {
        "image": "scene_039.png",
        "triggerText": "These people lived 15,000 years ago,"
      },
      {
        "image": "scene_040.png",
        "triggerText": "long before the invention of agriculture."
      },
      {
        "image": "scene_041.png",
        "triggerText": "Scientists expected healthy mouths."
      },
      {
        "image": "scene_042.png",
        "triggerText": "What they found was a disaster."
      },
      {
        "image": "scene_043.png",
        "triggerText": "More than half of the teeth had deep cavities."
      },
      {
        "image": "scene_044.png",
        "triggerText": "Only three skeletons out of 52 showed no signs of decay."
      },
      {
        "image": "scene_045.png",
        "triggerText": "The lead author,"
      },
      {
        "image": "scene_046.png",
        "triggerText": "paleobiologist Louise Humphrey of London's Natural History Museum,"
      },
      {
        "image": "scene_047.png",
        "triggerText": "said the rate was comparable to modern populations eating refined sugar."
      },
      {
        "image": "scene_048.png",
        "triggerText": "The culprit?"
      },
      {
        "image": "scene_049.png",
        "triggerText": "Acorns. These hunter-gatherers gathered sweet acorns by the bucket,"
      },
      {
        "image": "scene_050.png",
        "triggerText": "crushed them,"
      },
      {
        "image": "scene_051.png",
        "triggerText": "turned them into a sticky paste loaded with carbohydrates."
      },
      {
        "image": "scene_052.png",
        "triggerText": "That paste clung to teeth,"
      },
      {
        "image": "scene_053.png",
        "triggerText": "fermented, and fed the bacteria that cause cavities."
      },
      {
        "image": "scene_054.png",
        "triggerText": "The conclusion is brutal."
      },
      {
        "image": "scene_055.png",
        "triggerText": "Our ancestors didn't have perfect mouths."
      },
      {
        "image": "scene_056.png",
        "triggerText": "They suffered."
      },
      {
        "image": "scene_057.png",
        "triggerText": "And dental suffering in the ancient world is something we've completely forgotten."
      },
      {
        "image": "scene_058.png",
        "triggerText": "An untreated cavity doesn't stay a cavity."
      },
      {
        "image": "scene_059.png",
        "triggerText": "It grows."
      },
      {
        "image": "scene_060.png",
        "triggerText": "It reaches the pulp."
      },
      {
        "image": "scene_061.png",
        "triggerText": "It becomes an abscess."
      },
      {
        "image": "scene_062.png",
        "triggerText": "The abscess swells."
      },
      {
        "image": "scene_063.png",
        "triggerText": "It can migrate into the jaw,"
      },
      {
        "image": "scene_064.png",
        "triggerText": "into the neck,"
      },
      {
        "image": "scene_065.png",
        "triggerText": "into the brain."
      },
      {
        "image": "scene_066.png",
        "triggerText": "Before antibiotics,"
      },
      {
        "image": "scene_067.png",
        "triggerText": "a dental infection could kill you in weeks."
      },
      {
        "image": "scene_068.png",
        "triggerText": "Archaeologists have found countless ancient skulls with holes punched through the jawbone,"
      },
      {
        "image": "scene_069.png",
        "triggerText": "craters of eaten-away bone left by abscesses that were never treated."
      },
      {
        "image": "scene_070.png",
        "triggerText": "On the Taforalt skeletons,"
      },
      {
        "image": "scene_071.png",
        "triggerText": "90% of individuals had lost their incisors."
      },
      {
        "image": "scene_072.png",
        "triggerText": "Some from ritual."
      },
      {
        "image": "scene_073.png",
        "triggerText": "Many from disease."
      },
      {
        "image": "scene_074.png",
        "triggerText": "An infected tooth in the Stone Age was a death sentence."
      },
      {
        "image": "scene_075.png",
        "triggerText": "And it didn't just kill quickly."
      },
      {
        "image": "scene_076.png",
        "triggerText": "It killed slowly."
      },
      {
        "image": "scene_077.png",
        "triggerText": "Days of fever."
      },
      {
        "image": "scene_078.png",
        "triggerText": "Weeks of swelling."
      },
      {
        "image": "scene_079.png",
        "triggerText": "A face deformed by pressure from inside."
      },
      {
        "image": "scene_080.png",
        "triggerText": "But our ancestors didn't just sit there and wait to die."
      },
      {
        "image": "scene_081.png",
        "triggerText": "Here's where it gets fascinating."
      },
      {
        "image": "scene_082.png",
        "triggerText": "In 2006,"
      },
      {
        "image": "scene_083.png",
        "triggerText": "a study published in Nature dropped like a bomb on the anthropology world."
      },
      {
        "image": "scene_084.png",
        "triggerText": "Researchers had analyzed 300 skeletons from a Neolithic site called Mehrgarh,"
      },
      {
        "image": "scene_085.png",
        "triggerText": "in modern-day Pakistan."
      },
      {
        "image": "scene_086.png",
        "triggerText": "Out of those 300 individuals,"
      },
      {
        "image": "scene_087.png",
        "triggerText": "nine had something unexpected."
      },
      {
        "image": "scene_088.png",
        "triggerText": "Eleven teeth in total,"
      },
      {
        "image": "scene_089.png",
        "triggerText": "with perfectly round holes drilled straight into the enamel."
      },
      {
        "image": "scene_090.png",
        "triggerText": "Not holes caused by decay."
      },
      {
        "image": "scene_091.png",
        "triggerText": "Drilled holes."
      },
      {
        "image": "scene_092.png",
        "triggerText": "Deliberately."
      },
      {
        "image": "scene_093.png",
        "triggerText": "With a tool. The teeth dated to between 7,500 and 9,000 years old."
      },
      {
        "image": "scene_094.png",
        "triggerText": "That's two thousand years before the invention of writing."
      },
      {
        "image": "scene_095.png",
        "triggerText": "The lead author,"
      },
      {
        "image": "scene_096.png",
        "triggerText": "anthropologist David Frayer of the University of Kansas,"
      },
      {
        "image": "scene_097.png",
        "triggerText": "called it the oldest known case of dentistry performed on a living human being."
      },
      {
        "image": "scene_098.png",
        "triggerText": "And this wasn't a one-time experiment."
      },
      {
        "image": "scene_099.png",
        "triggerText": "The practice lasted 1,500 years at the same site."
      },
      {
        "image": "scene_100.png",
        "triggerText": "For fifteen centuries,"
      },
      {
        "image": "scene_101.png",
        "triggerText": "men and women of Mehrgarh visited what can only be called the first dentists in history."
      },
      {
        "image": "scene_102.png",
        "triggerText": "So how do you drill a tooth nine thousand years ago,"
      },
      {
        "image": "scene_103.png",
        "triggerText": "with no electricity,"
      },
      {
        "image": "scene_104.png",
        "triggerText": "no steel,"
      },
      {
        "image": "scene_105.png",
        "triggerText": "no anesthesia?"
      },
      {
        "image": "scene_106.png",
        "triggerText": "The answer is simple and terrifying."
      },
      {
        "image": "scene_107.png",
        "triggerText": "With a bow drill."
      },
      {
        "image": "scene_108.png",
        "triggerText": "The people of Mehrgarh were already master craftsmen."
      },
      {
        "image": "scene_109.png",
        "triggerText": "They made beads out of lapis lazuli and turquoise,"
      },
      {
        "image": "scene_110.png",
        "triggerText": "drilling tiny holes through them using flint tips mounted on a bow."
      },
      {
        "image": "scene_111.png",
        "triggerText": "The bow spun the flint at high speed."
      },
      {
        "image": "scene_112.png",
        "triggerText": "It's the same principle as starting a fire by friction."
      },
      {
        "image": "scene_113.png",
        "triggerText": "They simply transferred the technology from the bead to the molar."
      },
      {
        "image": "scene_114.png",
        "triggerText": "Picture the scene."
      },
      {
        "image": "scene_115.png",
        "triggerText": "You're lying on the ground."
      },
      {
        "image": "scene_116.png",
        "triggerText": "One man holds your head still."
      },
      {
        "image": "scene_117.png",
        "triggerText": "Another kneels beside you with a wooden bow in his hands."
      },
      {
        "image": "scene_118.png",
        "triggerText": "He brings a sharp flint drill toward your tooth."
      },
      {
        "image": "scene_119.png",
        "triggerText": "He starts spinning it."
      },
      {
        "image": "scene_120.png",
        "triggerText": "You feel the vibration through your entire jaw,"
      },
      {
        "image": "scene_121.png",
        "triggerText": "into your skull,"
      },
      {
        "image": "scene_122.png",
        "triggerText": "into your eyes."
      },
      {
        "image": "scene_123.png",
        "triggerText": "The heat rises."
      },
      {
        "image": "scene_124.png",
        "triggerText": "Smoke curls from your mouth."
      },
      {
        "image": "scene_125.png",
        "triggerText": "Tooth dust fills your tongue."
      },
      {
        "image": "scene_126.png",
        "triggerText": "There's nothing to bite down on."
      },
      {
        "image": "scene_127.png",
        "triggerText": "Nothing to numb the nerve."
      },
      {
        "image": "scene_128.png",
        "triggerText": "Researchers later replicated the procedure on detached human teeth."
      },
      {
        "image": "scene_129.png",
        "triggerText": "They drilled a hole resembling the Mehrgarh marks in about a minute."
      },
      {
        "image": "scene_130.png",
        "triggerText": "One minute of torture."
      },
      {
        "image": "scene_131.png",
        "triggerText": "And the patients survived."
      },
      {
        "image": "scene_132.png",
        "triggerText": "The healing marks around the drilled holes prove the operations were done on living people,"
      },
      {
        "image": "scene_133.png",
        "triggerText": "who got up and walked away."
      },
      {
        "image": "scene_134.png",
        "triggerText": "But drilling the hole is only half the job."
      },
      {
        "image": "scene_135.png",
        "triggerText": "The other half is filling it."
      },
      {
        "image": "scene_136.png",
        "triggerText": "And here,"
      },
      {
        "image": "scene_137.png",
        "triggerText": "another stunning discovery enters the picture."
      },
      {
        "image": "scene_138.png",
        "triggerText": "In 2012,"
      },
      {
        "image": "scene_139.png",
        "triggerText": "a study published in PLoS ONE analyzed a human jawbone from Slovenia,"
      },
      {
        "image": "scene_140.png",
        "triggerText": "6,500 years old."
      },
      {
        "image": "scene_141.png",
        "triggerText": "On the left canine,"
      },
      {
        "image": "scene_142.png",
        "triggerText": "researchers noticed something strange."
      },
      {
        "image": "scene_143.png",
        "triggerText": "A vertical crack,"
      },
      {
        "image": "scene_144.png",
        "triggerText": "coated with a yellowish substance."
      },
      {
        "image": "scene_145.png",
        "triggerText": "They scanned the tooth using synchrotron X-ray imaging,"
      },
      {
        "image": "scene_146.png",
        "triggerText": "one of the most powerful techniques on the planet."
      },
      {
        "image": "scene_147.png",
        "triggerText": "The yellow substance was beeswax."
      },
      {
        "image": "scene_148.png",
        "triggerText": "Someone,"
      },
      {
        "image": "scene_149.png",
        "triggerText": "6,500 years ago, had taken beeswax and carefully applied it to seal a painful crack in a human tooth."
      },
      {
        "image": "scene_150.png",
        "triggerText": "It's the oldest known dental filling on Earth."
      },
      {
        "image": "scene_151.png",
        "triggerText": "The wax probably reduced sensitivity and dulled the constant ache."
      },
      {
        "image": "scene_152.png",
        "triggerText": "We don't know if the patient survived long after."
      },
      {
        "image": "scene_153.png",
        "triggerText": "We don't know who applied the wax."
      },
      {
        "image": "scene_154.png",
        "triggerText": "But we know one thing."
      },
      {
        "image": "scene_155.png",
        "triggerText": "Someone, somewhere,"
      },
      {
        "image": "scene_156.png",
        "triggerText": "was trying to help."
      },
      {
        "image": "scene_157.png",
        "triggerText": "And these weren't isolated cases."
      },
      {
        "image": "scene_158.png",
        "triggerText": "Across the ancient world,"
      },
      {
        "image": "scene_159.png",
        "triggerText": "the war against tooth pain was constant and creative."
      },
      {
        "image": "scene_160.png",
        "triggerText": "The Egyptians wrote remedies on papyrus."
      },
      {
        "image": "scene_161.png",
        "triggerText": "The Ebers Papyrus,"
      },
      {
        "image": "scene_162.png",
        "triggerText": "dating to around 1550 BC,"
      },
      {
        "image": "scene_163.png",
        "triggerText": "lists treatments mixing honey,"
      },
      {
        "image": "scene_164.png",
        "triggerText": "flour,"
      },
      {
        "image": "scene_165.png",
        "triggerText": "and ground minerals, applied directly to aching teeth."
      },
      {
        "image": "scene_166.png",
        "triggerText": "Most ancient cultures believed cavities were caused by a tiny worm burrowing inside the tooth."
      },
      {
        "image": "scene_167.png",
        "triggerText": "A Babylonian clay tablet,"
      },
      {
        "image": "scene_168.png",
        "triggerText": "dating to roughly the 18th century BC,"
      },
      {
        "image": "scene_169.png",
        "triggerText": "describes a creature called the tooth worm that drank blood and gnawed the roots."
      },
      {
        "image": "scene_170.png",
        "triggerText": "The Babylonians were wrong about the worm,"
      },
      {
        "image": "scene_171.png",
        "triggerText": "but right that something invisible was eating the enamel."
      },
      {
        "image": "scene_172.png",
        "triggerText": "To kill it,"
      },
      {
        "image": "scene_173.png",
        "triggerText": "healers burned henbane seeds and funneled the smoke into the patient's open mouth."
      },
      {
        "image": "scene_174.png",
        "triggerText": "The smoke contained narcotics."
      },
      {
        "image": "scene_175.png",
        "triggerText": "It probably did dull the pain."
      },
      {
        "image": "scene_176.png",
        "triggerText": "It also probably didn't kill anything."
      },
      {
        "image": "scene_177.png",
        "triggerText": "The Romans used crushed eggshells and oyster shells as primitive toothpaste."
      },
      {
        "image": "scene_178.png",
        "triggerText": "They also pulled rotten teeth with iron forceps,"
      },
      {
        "image": "scene_179.png",
        "triggerText": "sometimes successfully,"
      },
      {
        "image": "scene_180.png",
        "triggerText": "often not."
      },
      {
        "image": "scene_181.png",
        "triggerText": "Around 700 BC,"
      },
      {
        "image": "scene_182.png",
        "triggerText": "Etruscan craftsmen in modern-day Italy built actual dental bridges out of gold wire and human or animal teeth,"
      },
      {
        "image": "scene_183.png",
        "triggerText": "attached to the patient's remaining molars."
      },
      {
        "image": "scene_184.png",
        "triggerText": "They look surprisingly close to what dentists still make today."
      },
      {
        "image": "scene_185.png",
        "triggerText": "The technology was real."
      },
      {
        "image": "scene_186.png",
        "triggerText": "The pain relief was minimal."
      },
      {
        "image": "scene_187.png",
        "triggerText": "But for most people,"
      },
      {
        "image": "scene_188.png",
        "triggerText": "in most places,"
      },
      {
        "image": "scene_189.png",
        "triggerText": "in most of history,"
      },
      {
        "image": "scene_190.png",
        "triggerText": "the only real treatment was pulling the tooth out."
      },
      {
        "image": "scene_191.png",
        "triggerText": "And pulling a tooth without anesthesia is one of the worst things a human body can experience."
      },
      {
        "image": "scene_192.png",
        "triggerText": "In medieval Europe,"
      },
      {
        "image": "scene_193.png",
        "triggerText": "the job often fell to the village barber."
      },
      {
        "image": "scene_194.png",
        "triggerText": "The barber-surgeon would sit the patient in a chair,"
      },
      {
        "image": "scene_195.png",
        "triggerText": "hold their head between his knees,"
      },
      {
        "image": "scene_196.png",
        "triggerText": "and yank the tooth with iron pliers."
      },
      {
        "image": "scene_197.png",
        "triggerText": "No sterilization."
      },
      {
        "image": "scene_198.png",
        "triggerText": "Infections were common."
      },
      {
        "image": "scene_199.png",
        "triggerText": "Many patients died from sepsis after the operation."
      },
      {
        "image": "scene_200.png",
        "triggerText": "Some doctors recommended drinking large amounts of wine beforehand to dull the senses."
      },
      {
        "image": "scene_201.png",
        "triggerText": "Others used opium when they could find it."
      },
      {
        "image": "scene_202.png",
        "triggerText": "But for the average peasant,"
      },
      {
        "image": "scene_203.png",
        "triggerText": "you just gripped the chair,"
      },
      {
        "image": "scene_204.png",
        "triggerText": "closed your eyes,"
      },
      {
        "image": "scene_205.png",
        "triggerText": "and prayed."
      },
      {
        "image": "scene_206.png",
        "triggerText": "Tooth-pulling was so dramatic that traveling dentists in Renaissance Europe performed extractions in public squares,"
      },
      {
        "image": "scene_207.png",
        "triggerText": "with musicians playing loudly to cover the screams."
      },
      {
        "image": "scene_208.png",
        "triggerText": "The screaming was part of the show."
      },
      {
        "image": "scene_209.png",
        "triggerText": "Now here's the question nobody asks."
      },
      {
        "image": "scene_210.png",
        "triggerText": "If dental pain was this brutal,"
      },
      {
        "image": "scene_211.png",
        "triggerText": "why didn't humans go extinct from infections?"
      },
      {
        "image": "scene_212.png",
        "triggerText": "The answer is a mix of luck and biology."
      },
      {
        "image": "scene_213.png",
        "triggerText": "The human body has an extraordinary ability to wall off chronic infections."
      },
      {
        "image": "scene_214.png",
        "triggerText": "An abscess,"
      },
      {
        "image": "scene_215.png",
        "triggerText": "instead of spreading,"
      },
      {
        "image": "scene_216.png",
        "triggerText": "often forms a hard capsule of pus and dies down on its own."
      },
      {
        "image": "scene_217.png",
        "triggerText": "The body sacrifices the tooth,"
      },
      {
        "image": "scene_218.png",
        "triggerText": "drains the wound through a hole in the gum,"
      },
      {
        "image": "scene_219.png",
        "triggerText": "and survives."
      },
      {
        "image": "scene_220.png",
        "triggerText": "Archaeologists looking at ancient jawbones routinely find these healed sinus tracts,"
      },
      {
        "image": "scene_221.png",
        "triggerText": "tiny tunnels through the bone where pus drained for years."
      },
      {
        "image": "scene_222.png",
        "triggerText": "People learned to live with it."
      },
      {
        "image": "scene_223.png",
        "triggerText": "A constant low-grade pain."
      },
      {
        "image": "scene_224.png",
        "triggerText": "A face permanently swollen."
      },
      {
        "image": "scene_225.png",
        "triggerText": "A jaw missing half its teeth by age 30."
      },
      {
        "image": "scene_226.png",
        "triggerText": "Skeletons from ancient farming villages frequently show adults who lost 10 to 15 teeth by middle age and survived anyway."
      },
      {
        "image": "scene_227.png",
        "triggerText": "They chewed soft food."
      },
      {
        "image": "scene_228.png",
        "triggerText": "They mashed grains into porridge."
      },
      {
        "image": "scene_229.png",
        "triggerText": "They drank broth."
      },
      {
        "image": "scene_230.png",
        "triggerText": "The body adapted."
      },
      {
        "image": "scene_231.png",
        "triggerText": "But the real reason humanity survived without dentists isn't biology."
      },
      {
        "image": "scene_232.png",
        "triggerText": "It's culture."
      },
      {
        "image": "scene_233.png",
        "triggerText": "For thousands of years,"
      },
      {
        "image": "scene_234.png",
        "triggerText": "every society on Earth built knowledge about teeth and passed it on."
      },
      {
        "image": "scene_235.png",
        "triggerText": "Which herbs reduced swelling."
      },
      {
        "image": "scene_236.png",
        "triggerText": "Which plants numbed the gums."
      },
      {
        "image": "scene_237.png",
        "triggerText": "Clove oil was used in ancient China and India more than 2,000 years ago,"
      },
      {
        "image": "scene_238.png",
        "triggerText": "and modern science confirms it contains eugenol,"
      },
      {
        "image": "scene_239.png",
        "triggerText": "a natural anesthetic still used in dental products today."
      },
      {
        "image": "scene_240.png",
        "triggerText": "Willow bark,"
      },
      {
        "image": "scene_241.png",
        "triggerText": "chewed across Europe and North America,"
      },
      {
        "image": "scene_242.png",
        "triggerText": "contains salicin,"
      },
      {
        "image": "scene_243.png",
        "triggerText": "the molecule that became aspirin."
      },
      {
        "image": "scene_244.png",
        "triggerText": "People didn't know the chemistry,"
      },
      {
        "image": "scene_245.png",
        "triggerText": "but they knew it worked."
      },
      {
        "image": "scene_246.png",
        "triggerText": "Grandmothers passed remedies to mothers."
      },
      {
        "image": "scene_247.png",
        "triggerText": "Healers traded recipes."
      },
      {
        "image": "scene_248.png",
        "triggerText": "Every generation built on the last."
      },
      {
        "image": "scene_249.png",
        "triggerText": "Slowly, painfully,"
      },
      {
        "image": "scene_250.png",
        "triggerText": "humanity accumulated thousands of tiny pieces of dental wisdom,"
      },
      {
        "image": "scene_251.png",
        "triggerText": "none of them perfect,"
      },
      {
        "image": "scene_252.png",
        "triggerText": "all of them keeping the species alive."
      },
      {
        "image": "scene_253.png",
        "triggerText": "In 1728,"
      },
      {
        "image": "scene_254.png",
        "triggerText": "a French surgeon named Pierre Fauchard published a book called Le Chirurgien Dentiste."
      },
      {
        "image": "scene_255.png",
        "triggerText": "For the first time,"
      },
      {
        "image": "scene_256.png",
        "triggerText": "dentistry became a real scientific profession."
      },
      {
        "image": "scene_257.png",
        "triggerText": "Fauchard described drills,"
      },
      {
        "image": "scene_258.png",
        "triggerText": "fillings, dentures,"
      },
      {
        "image": "scene_259.png",
        "triggerText": "and even braces."
      },
      {
        "image": "scene_260.png",
        "triggerText": "He's now called the father of modern dentistry."
      },
      {
        "image": "scene_261.png",
        "triggerText": "But everything he wrote stood on top of 9,000 years of trial and error."
      },
      {
        "image": "scene_262.png",
        "triggerText": "From the bow drill of Mehrgarh to the beeswax of Slovenia,"
      },
      {
        "image": "scene_263.png",
        "triggerText": "from the Egyptian honey paste to the Etruscan gold bridge,"
      },
      {
        "image": "scene_264.png",
        "triggerText": "every generation handed down what it knew."
      },
      {
        "image": "scene_265.png",
        "triggerText": "And every generation gritted its teeth,"
      },
      {
        "image": "scene_266.png",
        "triggerText": "literally, and endured what we will never have to."
      },
      {
        "image": "scene_267.png",
        "triggerText": "For 300,000 years,"
      },
      {
        "image": "scene_268.png",
        "triggerText": "your ancestors woke up every morning hoping their teeth would hold one more day."
      },
      {
        "image": "scene_269.png",
        "triggerText": "They chewed carefully."
      },
      {
        "image": "scene_270.png",
        "triggerText": "They flinched when cold water touched a cavity."
      },
      {
        "image": "scene_271.png",
        "triggerText": "They felt the slow,"
      },
      {
        "image": "scene_272.png",
        "triggerText": "terrifying progression of an infection deep inside their jaw,"
      },
      {
        "image": "scene_273.png",
        "triggerText": "knowing no doctor could save them."
      },
      {
        "image": "scene_274.png",
        "triggerText": "And yet they kept going."
      },
      {
        "image": "scene_275.png",
        "triggerText": "They invented tools,"
      },
      {
        "image": "scene_276.png",
        "triggerText": "plants, prayers,"
      },
      {
        "image": "scene_277.png",
        "triggerText": "and procedures,"
      },
      {
        "image": "scene_278.png",
        "triggerText": "all to fight an enemy hidden inside their own mouths."
      },
      {
        "image": "scene_279.png",
        "triggerText": "They never had a single painless day."
      },
      {
        "image": "scene_280.png",
        "triggerText": "Not one."
      },
      {
        "image": "scene_281.png",
        "triggerText": "Not in three hundred thousand years."
      },
      {
        "image": "scene_282.png",
        "triggerText": "We sit in a chair now and forget all of it in an hour."
      },
      {
        "image": "scene_283.png",
        "triggerText": "They lived with the pain their entire lives,"
      },
      {
        "image": "scene_284.png",
        "triggerText": "and somehow built civilizations anyway."
      }
    ]
  },
