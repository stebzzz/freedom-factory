# Copy to .env.production at the repo root on the VPS, then fill in real keys.
# docker-compose.yml reads this file via `env_file:` — do NOT commit the real one.

# ─── Claude (script generation, prompt improvement) ──────────────────────
ANTHROPIC_API_KEY=

# ─── fal.ai (Flux 2 Pro, Seedream 5.0, Imagen 4 Fast, Wan 2.1) ───────────
FAL_KEY=

# ─── ElevenLabs (voiceover) ──────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Fish Speech via SiliconFlow (alternative voiceover) ─────────────────
SILICONFLOW_API_KEY=

# ─── Background music (optional) ─────────────────────────────────────────
MUBERT_API_KEY=
SUNO_API_KEY=

# ─── GenAIPro (Veo V2 — create-image / frames-to-video) ──────────────────
GENAIPRO_API_KEY=

# ─── Geminigen / Google AI Studio / Dashscope ────────────────────────────
GEMINIGEN_API_KEY=
GOOGLE_AI_STUDIO_KEY=
DASHSCOPE_API_KEY=

# ─── Runtime tweaks (already set in the Dockerfile, override if needed) ──
# WHISPER_CLI_PATH=/usr/local/bin/whisper-cli
# MAGICK_BIN=/usr/bin/magick
# REMOTION_CHROME_EXECUTABLE=/usr/bin/chromium
# PORT=3000
# HOSTNAME=0.0.0.0
